modules = ["nodejs-20", "web", "bash", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3001/tcp 2>/dev/null; PORT=3001 NODE_ENV=development pnpm --filter @workspace/api-server run dev"
waitForPort = 3001

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/aleajayhi run build && PORT=5000 NODE_ENV=development pnpm --filter @workspace/api-server run dev"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 8085
externalPort = 5000

[[ports]]
localPort = 8086
externalPort = 6000

[[ports]]
localPort = 21621
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=3001 NODE_ENV=production node --enable-source-maps artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/aleajayhi run build && pnpm --filter @workspace/api-server run build"]

[userenv]

[userenv.shared]
ADMIN_TOKEN = "J12345o12345@"
